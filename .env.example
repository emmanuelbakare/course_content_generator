# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_LOG_LEVEL=INFO

# Database. SQLite is used when these are left blank.
# DATABASE_URL=postgresql://user:password@localhost:5432/course_generator
DJANGO_DB_CONN_MAX_AGE=60

# Celery / Redis. Start Redis before running a worker.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# Staff operational reporting window and non-terminal-job alert threshold.
OPERATIONS_METRICS_DAYS=30
OPERATIONS_STUCK_JOB_MINUTES=30

# Production HTTPS and cookie settings. Set these when DJANGO_DEBUG=False.
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_USE_X_FORWARDED_PROTO=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_CSRF_TRUSTED_ORIGINS=https://courses.example.com

# Before a production release, run `python manage.py production_readiness`.
# It checks connectivity and configuration only; it never sends an LLM request.

# Configure providers in the Django admin, then set only the key variable used
# by that provider. Do not add API keys to the database or commit this file.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
